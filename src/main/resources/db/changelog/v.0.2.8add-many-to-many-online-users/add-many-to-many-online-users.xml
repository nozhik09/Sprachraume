<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                   https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="add-room-online-users-table" author="vladn09">
        <dropColumn tableName="room" columnName="online_users"/>

        <createTable tableName="room_online_users">
            <column name="room_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="user_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addForeignKeyConstraint
                constraintName="fk_room_online_users_room"
                baseTableName="room_online_users"
                baseColumnNames="room_id"
                referencedTableName="room"
                referencedColumnNames="id"/>

        <addForeignKeyConstraint
                constraintName="fk_room_online_users_user"
                baseTableName="room_online_users"
                baseColumnNames="user_id"
                referencedTableName="users"
                referencedColumnNames="id"/>
    </changeSet>
</databaseChangeLog>