<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                   https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="28.10.2024-create-keys-participant v2" author="vladn09">

        <addForeignKeyConstraint baseTableName="participant"
                                 baseColumnNames="room_id"
                                 constraintName="fk_participant_to_room"
                                 referencedTableName="room"
                                 referencedColumnNames="id"/>

        <addForeignKeyConstraint baseTableName="participant"
                                 baseColumnNames="user_id"
                                 constraintName="fk_participant_to_user"
                                 referencedTableName="users"
                                 referencedColumnNames="id"/>

        <addForeignKeyConstraint baseTableName="room"
                                 baseColumnNames="creator_id"
                                 constraintName="fk_room_to_user"
                                 referencedTableName="users"
                                 referencedColumnNames="id"/>

    </changeSet>
</databaseChangeLog>