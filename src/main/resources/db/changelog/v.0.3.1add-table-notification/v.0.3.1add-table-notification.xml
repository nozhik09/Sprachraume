<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                   https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="add-table-notification" author="vladn09">
        <createTable tableName="notification">
            <column name="id" type="bigint">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="user_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="actor_id" type="BIGINT"/>
            <column name="category" type="VARCHAR(16)">
                <constraints nullable="false"/>
            </column>
            <column name="title" type="TEXT"/>
            <column name="body" type="TEXT"/>
            <column name="context_type" type="VARCHAR(32)"/>
            <column name="context_id" type="BIGINT"/>
            <column name="is_read" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="TIMESTAMPTZ" defaultValueComputed="NOW()">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <createIndex tableName="notification" indexName="idx_notification_user_created">
            <column name="user_id"/>
            <column name="created_at" descending="true"/>
        </createIndex>

        <!-- Частичный индекс только для PostgreSQL -->
        <sql dbms="postgresql">
            CREATE INDEX idx_notification_user_unread
                ON notification (user_id, is_read)
                WHERE is_read = false;
        </sql>
    </changeSet>
</databaseChangeLog>