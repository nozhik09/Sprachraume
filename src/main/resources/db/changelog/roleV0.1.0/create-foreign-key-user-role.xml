<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                   https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="13.10.2024create-key-users-to-roles2 " author="vladn09">
        <addForeignKeyConstraint baseTableName="users_role"
                                 baseColumnNames="users_id"
                                 constraintName="fk_users_roles_to_user"
                                 referencedTableName="users"
                                 referencedColumnNames="id"
        />

        <addForeignKeyConstraint baseTableName="users_role"
                                 baseColumnNames="roles_id"
                                 constraintName="fk_users_roles_to_role"
                                 referencedTableName="roles"
                                 referencedColumnNames="id"
        />

    </changeSet>
</databaseChangeLog>